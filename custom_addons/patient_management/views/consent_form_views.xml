<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_consent_form" model="ir.ui.view">
        <field name="name">consent.form.view</field>
        <field name="model">consent.form</field>
        <field name="arch" type="xml">
            <form string="Consent Form">
                <sheet>
                    <group>
                        <field name="patient_name" readonly="1"/>
                        <field name="patient_mrn" readonly="1"/>
                        <field name="consent_language" required="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_download_consultation"
                            string="Download Consultation Consent Form"
                            type="object"
                            class="btn-primary"
                            invisible="not consent_language"/>

                    <button name="action_download_treatment"
                            string="Download Treatment Consent Form"
                            type="object"
                            class="btn-primary"
                            invisible="not consent_language"/>

                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>