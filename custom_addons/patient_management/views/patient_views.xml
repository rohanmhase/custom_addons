<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_patient_kanban" model="ir.ui.view">
        <field name="name">clinic.patient.kanban</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_view">
                <field name="name"/>
                <field name="enroll_date"/>
                <field name="total_sessions"/>
                <field name="remaining_sessions"/>
                <field name="first_xray_grade"/>
                <field name="latest_xray_grade"/>
                <field name="latest_xray_status"/>
                <field name="patient_status"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_card"
                             t-attf-class="oe_kanban_global_click {{ record.first_xray_grade.raw_value and record.latest_xray_grade.raw_value and record.first_xray_grade.raw_value == record.latest_xray_grade.raw_value ? 'border border-warning' : '' }}">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong>
                                    <field name="name"/>
                                </strong>

                                <span t-attf-class="badge rounded-pill {{ record.patient_status.raw_value === 'active' ? 'text-bg-success' : record.patient_status.raw_value === 'inactive' ? 'text-bg-danger' : 'text-bg-secondary' }}">
                                    <t t-esc="record.patient_status.value || 'visit'"/>
                                </span>

                            </div>
                            <div>
                                <strong>Date -</strong>
                                <field name="enroll_date"/>
                            </div>
                            <div>
                                <strong>Enrolled Sessions -</strong>
                                <field name="total_sessions"/>
                            </div>
                            <div>
                                <strong>Remaining Sessions -</strong>
                                <field name="remaining_sessions"/>
                            </div>
                            <div>
                                <strong>First X-Ray Grade -</strong>
                                <t t-if="record.first_xray_grade.raw_value">
                                    <field name="first_xray_grade"/>
                                    <span>(<field name="first_xray_day"/>)
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Not Available</span>
                                </t>
                            </div>
                            <div>
                                <strong>Latest X-Ray Grade -</strong>
                                <t t-if="record.latest_xray_grade.raw_value">
                                    <field name="latest_xray_grade"/>
                                    <span>(<field name="latest_xray_day"/>)
                                    </span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Not Available</span>
                                </t>
                            </div>
                            <div>
                                <strong>Latest X-Ray Status -</strong>
                                <t t-if="record.latest_xray_status.raw_value">
                                    <field name="latest_xray_status"/>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Not Available</span>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_patient_tree" model="ir.ui.view">
        <field name="name">clinic.patient.tree</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="mrn"/>
                <field name="enroll_date" string="Date(MM/DD/YYYY)"/>
                <field name="total_sessions" string="Enrolled Sessions"/>
                <field name="remaining_sessions"/>
                <field name="first_xray_grade"/>
                <field name="latest_xray_grade"/>
                <field name="latest_xray_status"/>
            </tree>
        </field>
    </record>

    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">clinic.patient.form</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header>
                    <button name="action_open_case_taking" type="object" string="Case Taking"/>
                    <button name="action_open_enrollment" type="object" string="Enrollment"/>
                    <button name="action_open_blood_report" type="object" string="Blood Report"/>
                    <button name="action_open_daily_followup" type="object" string="CS Followup"/>
                    <button name="action_open_assessment" type="object" string="RS Followup"/>
                    <button name="action_open_bm_followup" string="BM Follow-up" type="object" class="btn-secondary"/>
                    <button name="action_open_prescription" type="object" string="Prescription"/>
                    <button name="action_open_session" type="object" string="Therapy Session"/>
                    <button name="action_open_attachment" type="object" string="Attachment"/>
                    <button name="action_open_patient_case_paper" type="object" string="Patient Internal Summary"/>
                    <button name="action_open_patient_xray" type="object" string="View X-Rays"/>
                    <button name="action_open_pet_tracker" string="PET Tracker" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="phone" maxlength="10"/>
                        <field name="email"/>
                        <field name="address"/>
                        <field name="enroll_date"/>
                        <field name="mrn"/>
                        <field name="clinic_id"/>
                        <field name="admin_id"/>
                        <field name="is_existing"/>

                        <field name="treatment_status" widget="radio" options="{'horizontal': true}"/>
                        <field name="not_converted_reasons" invisible="treatment_status != 'not_converted'"
                               required="1"/>
                        <field name="not_applicable_reasons" invisible="treatment_status != 'not_applicable'"
                               required="1"/>
                        <field name="other_reason"
                               invisible="not_converted_reasons != 'others' and not_applicable_reasons != 'others'"
                               required="1"/>
                        <field name="treatment_updated_by" force_save="1"/>

                        <field name="patient_source" required="1"/>
                        <field name="source_event" options="{'no_create': True, 'no_open': True}"
                               invisible="patient_source != 'event'" required="1"/>

                        <field name="patient_status"
                               widget="radio"
                               options="{'horizontal': true}"
                               selection="[('active','Active'),('inactive','Inactive')]"
                               invisible="patient_status == 'visit'"/>
                    </group>
                    <field name="pain_types" invisible="1"/>
                    <group string="Registered For">
                        <field name="pain_knee"/>
                        <field name="pain_spine"/>
                        <field name="pain_diabetes"/>
                        <field name="pain_ra"/>
                        <field name="pain_ana"/>
                        <field name="pain_others"/>
                        <field name="others" invisible="not pain_others" required="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_clinic_patient_search" model="ir.ui.view">
        <field name="name">clinic.patient.search</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="mrn"/>
                <field name="enroll_date"/>

                <filter string="Today's Registered Patients"
                        name="today_patients"
                        domain="[('enroll_date', '=', context_today())]"/>

                <filter string="Has Active Enrollment"
                        name="has_active_enrollment"
                        domain="[('enrollment_ids.state', '=', 'active')]"/>

            </search>
        </field>
    </record>

