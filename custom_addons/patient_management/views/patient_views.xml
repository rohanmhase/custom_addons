    <record id="action_patient_bm_followup" model="ir.actions.act_window">
        <field name="name">BM Follow-up</field>
        <field name="res_model">patient.bm.followup</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_pet_tracker_root"
              name="PET Tracker"
              action="action_patient_experience_tracker"
              sequence="20"/>

    <menuitem id="menu_bm_followup_root"
              name="BM Follow-up"
              action="action_patient_bm_followup"
              sequence="30"/>

    <record id="action_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">clinic.patient</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_today_patients':1}</field>
        <field name="domain">[('clinic_id', '=', context.get('default_clinic_id'))]</field>
    </record>

