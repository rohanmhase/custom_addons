<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_enrollment_bill_popup_form" model="ir.ui.view">
        <field name="name">enrollment.bill.popup.form</field>
        <field name="model">enrollment.bill.popup</field>

        <field name="arch" type="xml">

            <form string="Create Bill Confirmation">

                <sheet>

                    <group>
                        <field name="total_amount" readonly="1"/>
                    </group>

                    <field name="line_ids" nolabel="1">

                        <tree create="0"
                              delete="0"
                              edit="0"
                        open="0">

                            <field name="service_product_id" string="Service"/>
                            <field name="total_sessions" string="Sessions"/>
                            <field name="total_amount" string="Amount"/>

                        </tree>

                    </field>

                </sheet>

                <footer>

                    <button name="action_yes"
                            string="Yes"
                            type="object"
                            class="btn-primary"/>

                    <button string="No"
                            special="cancel"
                            class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>