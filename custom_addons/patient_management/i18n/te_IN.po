msgstr "ఫలితం అవగాహన:"

#. module: patient_management
#: model_terms:ir.ui.view,arch_db:patient_management.consent_report_template
msgid "ResearchAyu -"
msgstr "ResearchAyu -"

#. module: patient_management
#: model_terms:ir.ui.view,arch_db:patient_management.consent_report_template
msgid "Understanding of Consultation:"
msgstr "సంప్రదింపు అవగాహన:"