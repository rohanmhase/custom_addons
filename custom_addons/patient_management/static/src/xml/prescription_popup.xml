<t t-name="PrescriptionPopupTemplate" owl="1">
    <div class="modal-dialog" style="max-width: 95%; width: 95%;">
        <div class="modal-content" style="height: 85vh;">

            <div class="modal-header">
                <h3>🩺 Prescription Queue</h3>
            </div>
            <div class="mb-3">
                <input type="text"
                       class="form-control"
                       placeholder="Search patient name..."
                       t-model="state.searchTerm"/>
            </div>
            <div class="modal-body" style="overflow-y: auto;">
                <table class="table table-black">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Medicines</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-foreach="filteredPrescriptions" t-as="rec" t-key="rec.id">
                            <tr t-att-style="!rec.is_today ? 'background-color:#f8d7da;' : ''"
                                t-att-class="rec.is_today ? 'fw-bold table-success' : ''">
                                <td>
                                    <t t-esc="rec.date"/>
                                    <t t-if="rec.is_today">
                                        <span class="badge bg-success ms-2">Today</span>
                                    </t>
                                    <t t-if="!rec.is_today">
                                        <span class="badge bg-danger ms-2">Old</span>
                                    </t>
                                </td>
                                <td>
                                    <t t-esc="rec.patient_name"/>
                                </td>
                                <td>
                                    <t t-esc="rec.doctor_name"/>
                                </td>

                                <td>
                                    <t t-foreach="rec.lines" t-as="l" t-key="l_index">
                                        <div>
                                            <t t-esc="l.name"/>
                                            x
                                            <t t-esc="l.qty"/>
                                        </div>
                                    </t>
                                </td>

                                <td>
                                    <button class="btn btn-success"
                                            t-on-click="() => this.selectPrescription(rec)">
                                        Load
                                    </button>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" t-on-click="cancel">Close</button>
            </div>

        </div>
    </div>
</t>