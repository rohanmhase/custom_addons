<t t-name="BillingQueuePopupTemplate" owl="1">

    <div class="modal-dialog" style="max-width: 95%; width: 95%;">
        <div class="modal-content" style="height: 85vh;">

            <div class="modal-header">
                <h3>📋 Patient Billing Queue</h3>
            </div>

            <div class="mb-3">
                <input type="text"
                       class="form-control"
                       placeholder="Search patient name..."
                       t-model="state.searchTerm"/>
            </div>

            <div class="modal-body" style="overflow-y: auto;">

                <table class="table table-black">

                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Patient</th>
                            <th>Doctor/BM</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        <t t-foreach="filteredRecords"
                           t-as="rec"
                           t-key="rec.queue_type + '_' + rec.id">

                            <tr
                                    t-att-style="!rec.is_today ? 'background-color:#f8d7da;' : ''"
                                    t-att-class="rec.is_today ? 'fw-bold table-success' : ''"
                            >

                                <!-- TYPE -->
                                <td>

                                    <t t-if="rec.queue_type === 'prescription'">
                                        <span class="badge bg-primary" style="font-size: medium;">
                                            Prescription
                                        </span>
                                    </t>

                                    <t t-if="rec.queue_type === 'enrollment'">
                                        <span class="badge bg-warning text-dark" style="font-size: medium;">
                                            Enrollment
                                        </span>
                                    </t>

                                </td>

                                <!-- DATE -->
                                <td>

                                    <t t-esc="rec.date"/>

                                    <t t-if="rec.is_today">
                                        <span class="badge bg-success ms-2">
                                            Today
                                        </span>
                                    </t>

                                    <t t-if="!rec.is_today">
                                        <span class="badge bg-danger ms-2">
                                            Old
                                        </span>
                                    </t>

                                </td>

                                <!-- PATIENT -->
                                <td>
                                    <t t-esc="rec.patient_name"/>
                                </td>

                                <!-- DOCTOR/BM -->
                                <td>

                                    <t t-if="rec.queue_type === 'prescription'">
                                        <t t-esc="rec.doctor_name"/>
                                    </t>

                                    <t t-if="rec.queue_type === 'enrollment'">
                                        <t t-esc="rec.bm_name"/>
                                    </t>

                                </td>

                                <!-- ITEMS -->
                                <td>

                                    <t t-foreach="rec.lines"
                                       t-as="l"
                                       t-key="l.product_id + '_' + l.qty + '_' + l.amount">

                                        <div>

                                            <t t-esc="l.name"/>

                                            x

                                            <t t-esc="l.qty"/>

                                            <t t-if="rec.queue_type === 'enrollment'">

                                                =

                                                <t t-esc="l.amount"/>

                                            </t>

                                        </div>

                                    </t>

                                </td>

                                <!-- TOTAL -->
                                <td>

                                    <t t-if="rec.queue_type === 'enrollment'">

                                        ₹
                                        <t t-esc="rec.total_amount"/>

                                    </t>

                                    <t t-if="rec.queue_type === 'prescription'">
                                        -
                                    </t>

                                </td>

                                <!-- ACTION -->
                                <td>

                                    <button
                                            class="btn btn-success"
                                            t-on-click="() => this.loadRecord(rec)"
                                    >
                                        Load
                                    </button>

                                </td>

                            </tr>

                        </t>

                    </tbody>

                </table>

            </div>

            <div class="modal-footer">

                <button
                        class="btn btn-secondary"
                        t-on-click="cancel"
                >
                    Close
                </button>

            </div>

        </div>
    </div>

</t>