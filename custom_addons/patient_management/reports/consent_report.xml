<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Technical "Wrapper" for Consultation -->
    <template id="report_consultation_wrapper">
        <t t-set="report_type" t-value="'consultation'"/>
        <t t-call="patient_management.consent_report_template"/>
    </template>

    <!-- 2. Technical "Wrapper" for Treatment -->
    <template id="report_treatment_wrapper">
        <t t-set="report_type" t-value="'treatment'"/>
        <t t-call="patient_management.consent_report_template"/>
    </template>

    <!-- 3. Consultation Action -->
    <record id="action_report_consultation_consent" model="ir.actions.report">
        <field name="name">Consultation Consent</field>
        <field name="model">consent.form</field>
        <field name="report_type">qweb-pdf</field>
        <!-- Point to the wrapper -->
        <field name="report_name">patient_management.report_consultation_wrapper</field>
        <field name="print_report_name">'Consultation_Consent_%s' % (object.patient_name)</field>
    </record>

    <!-- 4. Treatment Action -->
    <record id="action_report_treatment_consent" model="ir.actions.report">
        <field name="name">Treatment Consent</field>
        <field name="model">consent.form</field>
        <field name="report_type">qweb-pdf</field>
        <!-- Point to the wrapper -->
        <field name="report_name">patient_management.report_treatment_wrapper</field>
        <field name="print_report_name">'Treatment_Consent_%s' % (object.patient_name)</field>
    </record>
</odoo>