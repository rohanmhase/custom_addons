<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Wizard Form
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_bank_sales_audit_wizard_form" model="ir.ui.view">
        <field name="name">bank.sales.audit.wizard.form</field>
        <field name="model">bank.sales.audit.wizard</field>
        <field name="arch" type="xml">
            <form string="Run BANK VS HUB Collection Audit">
                <sheet>
                    <group>
                        <group string="Audit Parameters">
                            <field name="bank_config_id"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Bank Statement">
                            <field name="bank_statement_file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run_bank_vs_hub_audit"
                            string="Analyze &amp; Generate Matrix"
                            type="object"
                            class="btn-primary"/>
                    <button string="Discard"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Audit Result Lines Tree (standalone)
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_bank_sales_audit_line_tree" model="ir.ui.view">
        <field name="name">bank.sales.audit.line.tree</field>
        <field name="model">bank.sales.audit.line</field>
        <field name="arch" type="xml">
            <tree string="Audit Comparison Matrix"
                  create="false" edit="false" delete="false"
                  decoration-danger="difference &lt; 0 and resolution_state == 'open'"
                  decoration-success="(resolution_state == 'open' and difference == 0) or (resolution_state == 'resolved' and net_difference == 0)"
                  decoration-warning="difference &gt; 0 and resolution_state == 'open'">
                <field name="tid_number" string="TID"/>
                <field name="clinics_display" string="Clinic(s)"/>
                <field name="system_mode" string="Payment Mode"/>
                <field name="hub_amount" string="HUB Sales" sum="Total HUB"/>
                <field name="bank_amount" string="Bank Receipt" sum="Total Bank"/>
                <field name="difference" string="Variance" sum="Net Variance"/>
                <field name="resolution_state" string="Status"/>
                <field name="reason_id" string="Reason"/>
                <field name="note" string="Note"/>
                <field name="net_difference" string="Remaining Variance" sum="Total Remaining"/>
                <field name="pending_status"
                       string="Remaining Variance "
                       widget="badge"
                       decoration-success="pending_status == 'settled'"
                       decoration-warning="pending_status == 'open'"/>
                <field name="resolved_for_date" string="Resolved From"/>
                <field name="resolved_on_date" string="Resolved On"/>


                <!--
                    RESOLVE — visible whenever there is still SOMETHING to
                    act on. This covers:
                      - 1st pass: difference != 0, resolution_state='open'
                      - 2nd+ pass: line already resolved once but
                        net_difference != 0 (leftover gap still needs a
                        reason / settlement of its own)
                -->
                <button name="action_open_resolve_wizard"
                        type="object"
                        string="Resolve"
                        class="btn-link"
                        invisible="(resolution_state == 'open' and difference == 0) or (resolution_state == 'resolved' and net_difference == 0)"/>

                <!--
                    RESET — visible whenever this line has been resolved
                    at least once (resolution_state='resolved'), regardless
                    of whether a leftover gap remains. Reverts everything
                    this line did: reopens any pending it settled, deletes
                    any pending it created (if still open), clears
                    reason/note, sets resolution_state back to 'open'.
                -->
                <button name="action_reset_line_to_open"
                        type="object"
                        string="Reset"
                        class="btn-link text-danger"
                        confirm="Reset this line back to Open? Any reopened/created pending entries will be reverted."
                        invisible="resolution_state != 'resolved'"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Audit History — Search (Archived filter for soft-delete)
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_bank_sales_audit_history_search" model="ir.ui.view">
        <field name="name">bank.sales.audit.history.search</field>
        <field name="model">bank.sales.audit</field>
        <field name="arch" type="xml">
            <search string="Audit History">
                <field name="name"/>
                <field name="bank_config_id"/>
                <group expand="0" string="Group By">
                    <filter string="Bank" name="group_bank" context="{'group_by':'bank_config_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Audit History — Tree
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_bank_sales_audit_history_tree" model="ir.ui.view">
        <field name="name">bank.sales.audit.history.tree</field>
        <field name="model">bank.sales.audit</field>
        <field name="arch" type="xml">
            <tree string="Audit History" create="false" edit="false">
                <field name="name" string="Audit Run"/>
                <field name="bank_config_id" string="Bank"/>
                <field name="start_date" string="From"/>
                <field name="end_date" string="To"/>
                <field name="file_name" string="CSV File"/>
                <field name="run_by" string="Run By"/>
                <field name="run_date" string="Run On"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Audit History — Form (drill into result lines)
         NOTE: no "Reset Entire Audit" header button — resetting is done
         per-line via the Reset button in the embedded tree below.
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="view_bank_sales_audit_history_form" model="ir.ui.view">
        <field name="name">bank.sales.audit.history.form</field>
        <field name="model">bank.sales.audit</field>
        <field name="arch" type="xml">
            <form string="Audit Run Details" create="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Audit Info">
                            <field name="bank_config_id" readonly="1"/>
                            <field name="start_date" readonly="1"/>
                            <field name="end_date" readonly="1"/>
                            <field name="file_name" readonly="1"/>
                        </group>
                        <group string="Run Info">
                            <field name="run_by" readonly="1"/>
                            <field name="run_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Results">
                            <field name="line_ids" readonly="1" nolabel="1">
                                <tree decoration-danger="difference &lt; 0 and resolution_state == 'open'"
                                      decoration-success="(resolution_state == 'open' and difference == 0) or (resolution_state == 'resolved' and net_difference == 0)"
                                      decoration-warning="difference &gt; 0 and resolution_state == 'open'">
                                    <field name="tid_number" string="TID"/>
                                    <field name="clinics_display" string="Clinic(s)"/>
                                    <field name="system_mode" string="Payment Mode"/>
                                    <field name="hub_amount" string="HUB Sales" sum="Total HUB"/>
                                    <field name="bank_amount" string="Bank Receipt" sum="Total Bank"/>
                                    <field name="difference" string="Variance" sum="Net Variance"/>
                                    <field name="resolution_state" string="Status"/>
                                    <field name="reason_id" string="Reason"/>
                                    <field name="note" string="Note"/>
                                    <field name="net_difference" string="Remaining Gap" sum="Total Remaining"/>
                                    <field name="pending_status"
                                           string="Remaining Gap Status"
                                           widget="badge"
                                           decoration-success="pending_status == 'settled'"
                                           decoration-warning="pending_status == 'open'"/>
                                    <field name="resolved_for_date" string="Gap From Date"/>
                                    <field name="resolved_on_date" string="Cleared On Date"/>


                                    <button name="action_open_resolve_wizard"
                                            type="object"
                                            string="Resolve"
                                            class="btn-link"
                                            invisible="(resolution_state == 'open' and difference == 0) or (resolution_state == 'resolved' and net_difference == 0)"/>
                                    <button name="action_reset_line_to_open"
                                            type="object"
                                            string="Reset"
                                            class="btn-link text-danger"
                                            confirm="Reset this line back to Open? Any reopened/created pending entries will be reverted."
                                            invisible="resolution_state != 'resolved'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Window Actions
    ═══════════════════════════════════════════════════════════════════════ -->
    <record id="action_bank_sales_audit_wizard" model="ir.actions.act_window">
        <field name="name">Run Bank vs HUB Audit</field>
        <field name="res_model">bank.sales.audit.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_bank_sales_audit_history" model="ir.actions.act_window">
        <field name="name">Audit History</field>
        <field name="res_model">bank.sales.audit</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_bank_sales_audit_history_search"/>
        <field name="target">current</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Menu Structure
    ═══════════════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_bank_hub_audit_parent"
              name="Bank vs HUB Audit"
              parent="menu_account_automation_root"
              sequence="10"/>

    <menuitem id="menu_sub_bank_vs_hub_audit"
              name="Run Audit"
              parent="menu_bank_hub_audit_parent"
              action="action_bank_sales_audit_wizard"
              sequence="10"/>

    <menuitem id="menu_sub_bank_sales_audit_history"
              name="View History"
              parent="menu_bank_hub_audit_parent"
              action="action_bank_sales_audit_history"
              sequence="20"/>

</odoo>