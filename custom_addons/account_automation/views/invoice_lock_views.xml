<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         INVOICE FORM BANNER
    ============================================================ -->
    <record id="view_move_form_invoice_lock" model="ir.ui.view">
        <field name="name">account.move.form.invoice.lock</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="is_date_locked" invisible="1"/>
                <field name="lock_reason" invisible="1"/>
            </field>
            <xpath expr="//sheet" position="before">
                <div class="alert alert-danger text-center mb-0"
                     role="alert"
                     invisible="not is_date_locked">
                    <strong>Invoice Locked:</strong>
                    <field name="lock_reason" readonly="1" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         INVOICE LIST COLUMNS
    ============================================================ -->
    <record id="view_out_invoice_tree_invoice_lock" model="ir.ui.view">
        <field name="name">account.move.out.invoice.tree.lock</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="is_date_locked"
                       string="Locked"
                       widget="boolean"
                       optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_in_invoice_tree_invoice_lock" model="ir.ui.view">
        <field name="name">account.move.in.invoice.tree.lock</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="is_date_locked"
                       string="Locked"
                       widget="boolean"
                       optional="show"/>
            </field>
        </field>
    </record>

    <!-- ============================================================
         WIZARD FORM
    ============================================================ -->
    <record id="view_invoice_lock_wizard_form" model="ir.ui.view">
        <field name="name">invoice.lock.wizard.form</field>
        <field name="model">invoice.lock.wizard</field>
        <field name="arch" type="xml">
            <form string="Invoice Lock Management" create="0" edit="1" delete="0">

                <header>
                    <button name="action_apply"
                            string="Apply"
                            type="object"
                            class="oe_highlight"/>
                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>Invoice Lock Management</h1>
                    </div>

                    <div class="alert alert-info d-flex align-items-center"
                         role="alert">
                        <i class="fa fa-info-circle me-2"
                           style="font-size:1.2em;"/>
                        <div>
                            Invoices older than <strong>10 days</strong>
                            are automatically locked.
                            Current auto-lock cutoff:
                            <strong>
                                <field name="auto_lock_cutoff"
                                       readonly="1"
                                       nolabel="1"
                                       class="d-inline"/>
                            </strong>
                        </div>
                    </div>

                    <group>
                        <group string="Action">
                            <field name="action_type" widget="radio"/>
                            <field name="lock_date"
                                   invisible="action_type != 'lock'"
                                   required="action_type == 'lock'"/>
                        </group>

                        <group string="Template (Optional)">
                            <label for="template_id"/>
                            <div class="o_row">
                                <field name="template_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       placeholder="Select template..."/>
                                <button name="action_delete_template"
                                        type="object"
                                        icon="fa-trash"
                                        title="Delete template"
                                        class="btn-link text-danger"
                                        invisible="not template_id"
                                        confirm="Delete this template?"/>
                            </div>
                            <label for="new_template_name" string="Save as"/>
                            <div class="o_row">
                                <field name="new_template_name"
                                       nolabel="1"
                                       placeholder="New template name..."/>
                                <button name="action_save_template"
                                        type="object"
                                        icon="fa-save"
                                        title="Save as template"
                                        class="btn-link text-primary"/>
                            </div>
                        </group>
                    </group>

                    <notebook>

                        <page string="Select Companies" name="companies">
                            <field name="company_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Current Lock Status" name="status">
                            <field name="status_line_ids"
                                   nolabel="1"
                                   readonly="1">
                                <tree create="0" delete="0" edit="0">
                                    <field name="company_id"/>
                                    <field name="manual_lock_date"/>
                                    <field name="auto_lock_enabled"
                                           widget="boolean"/>
                                    <field name="auto_lock_cutoff"/>
                                    <field name="effective_lock_date"
                                           decoration-danger="effective_lock_date"/>
                                </tree>
                            </field>
                            <p class="text-muted mt-2">
                                <strong>Effective Lock</strong> = the later
                                of Manual Lock and Auto-Lock Cutoff.
                                If a company has no effective lock, all invoices
                                are editable.
                            </p>
                        </page>

                        <page string="Activity Log" name="activity">
                            <field name="audit_line_ids"
                                   nolabel="1"
                                   readonly="1">
                                <tree create="0" delete="0" edit="0"
                                      default_order="create_date desc">
                                    <field name="create_date"
                                           string="Date"
                                           widget="datetime"/>
                                    <field name="user_id"/>
                                    <field name="company_id"/>
                                    <field name="action"
                                           decoration-danger="action == 'lock'"
                                           decoration-success="action == 'unlock'"/>
                                    <field name="previous_lock_date"/>
                                    <field name="new_lock_date"/>
                                </tree>
                            </field>
                            <p class="text-muted mt-2">
                                Complete history of all lock/unlock actions.
                            </p>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="action_invoice_lock_wizard" model="ir.actions.act_window">
        <field name="name">Invoice Lock Management</field>
        <field name="res_model">invoice.lock.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

   <menuitem id="menu_invoice_lock_wizard"
          name="Invoice Lock Management"
          parent="account.menu_finance_configuration"
          action="action_invoice_lock_wizard"
          sequence="95"
          groups="account_automation.group_account_automation_admin"/>
</odoo>