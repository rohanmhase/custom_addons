<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_account_automation_dashboard" model="ir.actions.act_window">
        <field name="name">Account Automation Workspace</field>
        <field name="res_model">account.automation.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <record id="action_bank_sales_audit_pending_view" model="ir.actions.act_window">
        <field name="name">Pending Variance Audit</field>
        <field name="res_model">account.automation.dashboard</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="view_account_automation_dashboard_form" model="ir.ui.view">
        <field name="name">account.automation.dashboard.form</field>
        <field name="model">account.automation.dashboard</field>
        <field name="arch" type="xml">
            <form string="Account Automation Workspace" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title mb-4">
                        <h1 style="color: #111827; font-size: 28px; font-weight: 700;">Account Automation Workspace</h1>
                    </div>
                    <div class="row">

                        <!-- ── Card 1: Daily Sale Comparison ── -->
                        <div class="col-md-4 col-sm-6 p-2">
                            <div class="card p-3 shadow-sm border-0"
                                 style="background-color: #f9fafb; border: 1px solid #e5e7eb !important; border-radius: 8px; min-height: 165px; display: flex; flex-direction: column; justify-content: space-between;">
                                <div>
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="text-primary d-flex align-items-center justify-content-center rounded"
                                             style="font-size: 20px; background-color: #eff6ff; width: 40px; height: 40px;">
                                            <i class="fa fa-exchange" title="Exchange"/>
                                        </div>
                                        <h3 class="m-0 font-weight-bold ml-3" style="font-size: 16px; color: #1f2937;">
                                            Daily Sale Comparison
                                        </h3>
                                    </div>
                                    <p class="text-muted small m-0" style="line-height: 1.4;">Compare HUB sales
                                        statements against parsed PSMR billing metrics.
                                    </p>
                                </div>
                                <div class="d-flex justify-content-end gap-2 mt-3 pt-2 border-top"
                                     style="border-top: 1px solid #f3f4f6 !important;">
                                    <button name="action_view_history" string="View History" type="object"
                                            class="btn btn-secondary btn-sm"/>
                                    <button name="action_run_audit" string="Run New" type="object"
                                            class="btn btn-primary btn-sm"/>
                                </div>
                            </div>
                        </div>

                        <!-- ── Card 2: Bank vs HUB Audit ── -->
                        <div class="col-md-4 col-sm-6 p-2">
                            <div class="card p-3 shadow-sm border-0"
                                 style="background-color: #f9fafb; border: 1px solid #e5e7eb !important; border-radius: 8px; min-height: 165px; display: flex; flex-direction: column; justify-content: space-between;">
                                <div>
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="text-success d-flex align-items-center justify-content-center rounded"
                                             style="font-size: 20px; background-color: #f0fdf4; width: 40px; height: 40px;">
                                            <i class="fa fa-university" title="Bank"/>
                                        </div>
                                        <h3 class="m-0 font-weight-bold ml-3" style="font-size: 16px; color: #1f2937;">
                                            Bank vs HUB Audit
                                        </h3>
                                    </div>
                                    <p class="text-muted small m-0" style="line-height: 1.4;">
                                        Reconcile bank CSV receipts against POS collection totals per TID, split by
                                        payment mode.
                                    </p>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-3 pt-2"
                                     style="border-top: 1px solid #f3f4f6 !important;">
                                    <button name="account_automation.action_bank_sales_audit_pending"
                                            string="Pending Variance"
                                            type="action"
                                            class="btn btn-secondary btn-sm"/>
                                    <div class="d-flex gap-2">
                                        <button name="action_view_bank_hub_history"
                                                string="View History"
                                                type="object"
                                                class="btn btn-secondary btn-sm"/>
                                        <button name="action_run_bank_hub_audit"
                                                string="Run New"
                                                type="object"
                                                class="btn btn-primary btn-sm"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ── Card 3: Clinic Performance Report  (NEW) ── -->
                        <div class="col-md-4 col-sm-6 p-2">
                            <div class="card p-3 shadow-sm border-0"
                                 style="background-color: #f9fafb; border: 1px solid #e5e7eb !important; border-radius: 8px; min-height: 165px; display: flex; flex-direction: column; justify-content: space-between;">
                                <div>
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="text-warning d-flex align-items-center justify-content-center rounded"
                                             style="font-size: 20px; background-color: #fffbeb; width: 40px; height: 40px;">
                                            <i class="fa fa-bar-chart" title="Clinic Performance"/>
                                        </div>
                                        <h3 class="m-0 font-weight-bold ml-3" style="font-size: 16px; color: #1f2937;">
                                            Clinic Performance
                                        </h3>
                                    </div>
                                    <p class="text-muted small m-0" style="line-height: 1.4;">
                                        Compare sales, therapy sessions, therapist counts, medicine cost,
                                        rent, and RS doctors across all clinics for any period.
                                    </p>
                                </div>
                                <div class="d-flex justify-content-end gap-2 mt-3 pt-2"
                                     style="border-top: 1px solid #f3f4f6 !important;">
                                    <button name="action_view_clinic_performance_history"
                                            string="View History"
                                            type="object"
                                            class="btn btn-secondary btn-sm"/>
                                    <button name="action_run_clinic_performance"
                                            string="Run Report"
                                            type="object"
                                            class="btn btn-primary btn-sm"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_account_automation_root"
              name="Account Automation"
              action="action_account_automation_dashboard"
              sequence="45"/>
    <menuitem id="menu_account_automation_operations"
              name="Operations"
              parent="menu_account_automation_root"
              sequence="10"/>
    <menuitem id="menu_account_automation_config"
              name="Configuration"
              parent="menu_account_automation_root"
              sequence="20"/>

</odoo>
