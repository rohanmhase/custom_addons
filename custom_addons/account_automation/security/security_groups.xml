<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_account_automation" model="ir.module.category">
        <field name="name">Account Automation</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_account_automation_user" model="res.groups">
        <field name="name">User (Read Only)</field>
        <field name="category_id" ref="module_category_account_automation"/>
    </record>

    <record id="group_account_automation_moderator" model="res.groups">
        <field name="name">Moderator (Create/Read/Update)</field>
        <field name="category_id" ref="module_category_account_automation"/>
        <field name="implied_ids" eval="[(4, ref('group_account_automation_user'))]"/>
    </record>

    <record id="group_account_automation_admin" model="res.groups">
        <field name="name">Administrator (Full CRUD)</field>
        <field name="category_id" ref="module_category_account_automation"/>
        <field name="implied_ids" eval="[(4, ref('group_account_automation_moderator'))]"/>
    </record>

    <record id="group_comparison_user" model="res.groups"><field name="name">Z_Trash User</field></record>
    <record id="group_comparison_moderator" model="res.groups"><field name="name">Z_Trash Mod</field></record>
    <record id="group_comparison_admin" model="res.groups"><field name="name">Z_Trash Admin</field></record>
</odoo>