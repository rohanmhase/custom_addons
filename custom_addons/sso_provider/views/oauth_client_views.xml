<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_oauth_client_tree" model="ir.ui.view">
        <field name="name">oauth.client.tree</field>
        <field name="model">oauth.client</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="client_id"/>
                <field name="redirect_uri"/>
            </tree>
        </field>
    </record>

    <record id="view_oauth_client_form" model="ir.ui.view">
        <field name="name">oauth.client.form</field>
        <field name="model">oauth.client</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="redirect_uri"/>
                    </group>
                    <group string="Credentials">
                        <field name="client_id"/>
                        <field name="client_secret"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_oauth_client" model="ir.actions.act_window">
        <field name="name">OAuth Clients</field>
        <field name="res_model">oauth.client</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_oauth_client_root"
              name="OAuth SSO Clients"
              parent="base.menu_users"
              action="action_oauth_client"
              sequence="20"/>
</odoo>