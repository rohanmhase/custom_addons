<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_operational_fund" model="ir.module.category">
        <field name="name">Operational Funds</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_op_fund_custodian" model="res.groups">
        <field name="name">Tier 1: Fund Custodian (Clinic Level)</field>
        <field name="category_id" ref="module_category_operational_fund"/>
    </record>

    <record id="group_op_fund_manager" model="res.groups">
        <field name="name">Tier 2: Fund Manager (Regional / Group)</field>
        <field name="category_id" ref="module_category_operational_fund"/>
        <field name="implied_ids" eval="[(4, ref('group_op_fund_custodian'))]"/>
    </record>

    <record id="group_op_fund_controller" model="res.groups">
        <field name="name">Tier 3: Fund Controller (Global)</field>
        <field name="category_id" ref="module_category_operational_fund"/>
        <field name="implied_ids" eval="[(4, ref('group_op_fund_manager'))]"/>
    </record>

    <record id="rule_op_fund_allocation_custodian" model="ir.rule">
        <field name="name">Allocations: Custodian</field>
        <field name="model_id" ref="model_operational_fund_allocation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_op_fund_custodian'))]"/>
    </record>

    <record id="rule_op_fund_allocation_manager" model="ir.rule">
        <field name="name">Allocations: Manager</field>
        <field name="model_id" ref="model_operational_fund_allocation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_op_fund_manager'))]"/>
    </record>

    <record id="rule_op_fund_allocation_controller" model="ir.rule">
        <field name="name">Allocations: Controller</field>
        <field name="model_id" ref="model_operational_fund_allocation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_op_fund_controller'))]"/>
    </record>

    <record id="rule_op_fund_disbursement_custodian" model="ir.rule">
        <field name="name">Disbursements: Custodian (Own Records)</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_op_fund_custodian'))]"/>
    </record>

    <record id="rule_op_fund_disbursement_manager" model="ir.rule">
        <field name="name">Disbursements: Manager (Review All)</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_op_fund_manager'))]"/>
    </record>

    <record id="rule_op_fund_disbursement_controller" model="ir.rule">
        <field name="name">Disbursements: Controller (All Clinics)</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_op_fund_controller'))]"/>
    </record>
</odoo>