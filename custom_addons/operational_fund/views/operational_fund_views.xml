<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_op_fund_disbursement" model="ir.sequence">
        <field name="name">Operational Fund Disbursement</field>
        <field name="code">operational.fund.disbursement</field>
        <field name="prefix">OFD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_op_fund_allocation" model="ir.sequence">
        <field name="name">Operational Fund Recharge</field>
        <field name="code">operational.fund.allocation</field>
        <field name="prefix">DEP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="action_router_disbursements_intercept" model="ir.actions.server">
        <field name="name">Disbursements Controller Router</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="state">code</field>
        <field name="code">
            action = model.action_check_pending_allocations()
        </field>
    </record>

    <record id="action_router_dashboard_intercept" model="ir.actions.server">
        <field name="name">Dashboard Controller Router</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="state">code</field>
        <field name="code">
            action = model.action_check_pending_allocations_dashboard()
        </field>
    </record>

    <record id="view_op_fund_rejection_wizard_form" model="ir.ui.view">
        <field name="name">operational.fund.rejection.wizard.form</field>
        <field name="model">operational.fund.rejection.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Disbursement">
                <group>
                    <field name="disbursement_id" invisible="1"/>
                    <field name="reason" placeholder="Please provide a detailed reason..." required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" string="Confirm Reject" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_op_fund_allocation_wizard_form" model="ir.ui.view">
        <field name="name">operational.fund.allocation.wizard.form</field>
        <field name="model">operational.fund.allocation.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Fund Deposit">
                <sheet>
                    <div class="alert alert-danger text-center shadow-sm" role="alert" style="font-size:16px;">
                        <i class="fa fa-university me-2 fa-2x" title="Bank"></i><br/>
                        <strong>MANDATORY ACTION: PENDING HQ DEPOSIT</strong><br/>
                        Please upload your bank reference receipt below to clear your wallet and restore dashboard access.
                    </div>

                    <group col="2">
                        <group>
                            <field name="allocation_id" invisible="1"/>
                            <field name="amount" string="Transfer Amount (₹)" readonly="1"/>
                        </group>
                        <group>
                            <field name="notes" string="HQ Purpose Reference" readonly="1"/>
                        </group>
                    </group>

                    <group string="Audit Verification Proof">
                        <field name="ack_proof_file" filename="ack_proof_filename" string="Upload Bank Statement Snippet / Proof"/>
                        <field name="ack_proof_filename" invisible="1"/>
                    </group>

                    <div class="mt-4 mb-2 d-flex">
                        <button name="action_confirm_receipt" string="Verify &amp; Inject Balance" type="object" class="btn-success btn-lg text-uppercase fw-bold me-3"/>
                        <button name="action_close_and_continue" string="Close &amp; Continue to Drafts" type="object" class="btn-secondary btn-lg" form_novalidate="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_op_fund_disbursement_kanban" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.kanban</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile" sample="1" records_draggable="0">
                <field name="name"/>
                <field name="clinic_id"/>
                <field name="payee_display"/>
                <field name="amount"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title fs-5"><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_title text-end fw-bold text-success fs-5">₹ <field name="amount"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span class="text-muted"><i class="fa fa-building-o me-1" title="Clinic"></i> <field name="clinic_id"/></span><br/>
                                    <span class="text-muted"><i class="fa fa-user-o me-1" title="Payee"></i> <field name="payee_display"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_op_fund_disbursement_form" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.form</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <form string="Operational Fund Disbursement" delete="0">
                <header>
                    <button name="action_print_voucher" string="1. Print Voucher" type="object" class="btn-secondary" invisible="state == 'refunded'"/>

                    <button name="action_submit_for_approval" string="Submit for Approval" type="object" class="oe_highlight" invisible="state != 'draft' or has_pending_allocation"/>

                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="state != 'waiting'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller"/>
                    <button name="action_mark_as_paid" string="Mark as Paid" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_unlock_for_correction" string="Unlock for Correction" type="object" class="btn-warning" invisible="state not in ('approved', 'paid')" groups="operational_fund.group_op_fund_manager" form_novalidate="1"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state in ('rejected', 'paid', 'refunded', 'refund_requested')" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>
                    <button name="action_request_refund" string="Request Refund" type="object" class="btn-warning" invisible="state not in ('approved', 'paid')" form_novalidate="1"/>
                    <button name="action_approve_refund" string="Approve Refund" type="object" class="btn-success" invisible="state != 'refund_requested'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>
                    <button name="action_cancel_refund" string="Deny Refund" type="object" class="btn-danger" invisible="state != 'refund_requested'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state not in ('rejected', 'approved', 'paid')" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>
                    <button name="action_delete_draft" string="Delete Draft" type="object" class="btn-secondary text-danger" invisible="state != 'draft'" form_novalidate="1"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting,approved,paid,refunded"/>
                </header>
                <sheet>
                    <field name="has_pending_allocation" invisible="1"/>

                    <div class="alert alert-danger d-flex align-items-center justify-content-between shadow-sm" role="alert" invisible="not has_pending_allocation" style="margin-bottom: 20px; padding: 15px;">
                        <div>
                            <i class="fa fa-university me-2 fa-2x align-middle" title="Bank"></i>
                            <span class="align-middle ms-2">
                                <strong>MANDATORY ACTION REQUIRED:</strong> This clinic has an unacknowledged capital deposit from HQ. You cannot submit vouchers until this balance is verified.
                            </span>
                        </div>
                        <button name="action_open_acknowledgment_wizard_from_banner" string="Upload Bank Proof Now" type="object" class="btn btn-danger btn-sm fw-bold text-uppercase border border-light" form_novalidate="1"/>
                    </div>

                    <div class="alert alert-info text-center" role="alert" invisible="signed_voucher_file or state in ('waiting', 'approved', 'paid', 'refund_requested', 'refunded')" style="margin-bottom: 20px;">
                        <i class="fa fa-info-circle me-2" title="Info"></i>
                        <strong>Action Required:</strong> Click <em>Print Voucher</em>, sign the physical document, and upload it below to unlock submission.
                    </div>

                    <div class="alert alert-danger text-center" role="alert" invisible="not is_cross_cluster_visit or state in ('approved', 'paid', 'refunded')" style="margin-bottom: 20px;">
                        <i class="fa fa-exclamation-triangle me-2" title="Warning"></i>
                        <strong>Cross-Cluster Alert:</strong> This patient is registered outside your clinic cluster. Manager approval is strictly required.
                    </div>

                    <div class="oe_title"><h1><field name="name"/></h1></div>

                    <group string="Legacy Record Information" invisible="not category or expense_category">
                        <group>
                            <field name="category" readonly="1" string="Legacy Category"/>
                            <field name="payee_type" readonly="1" invisible="category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')"/>
                            <field name="payee_id" readonly="1" invisible="payee_type != 'internal' or category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')"/>
                            <field name="vendor_name" readonly="1" invisible="payee_type != 'external' or category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')"/>
                            <field name="therapist_name" readonly="1" invisible="category not in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')"/>
                        </group>
                    </group>

                    <group invisible="category and not expense_category">
                        <group>
                            <field name="clinic_id" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')" force_save="1" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="date" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                            <field name="amount" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                        </group>

                        <group string="Expense Routing">
                            <field name="show_employee_payee" invisible="1"/>
                            <field name="show_therapist_name_input" invisible="1"/>
                            <field name="show_vendor_payee" invisible="1"/>
                            <field name="show_clinic_transfer" invisible="1"/>
                            <field name="show_home_visit" invisible="1"/>
                            <field name="show_therapist_role" invisible="1"/>
                            <field name="show_travel_type" invisible="1"/>
                            <field name="show_office_type" invisible="1"/>
                            <field name="show_other_expense" invisible="1"/>

                            <field name="expense_category" required="not category" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>

                            <field name="therapist_role" invisible="not show_therapist_role" required="show_therapist_role" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                            <field name="travel_type" invisible="not show_travel_type" required="show_travel_type" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                            <field name="office_expense_type" invisible="not show_office_type" required="show_office_type" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>

                            <field name="payee_id" string="Select Employee" invisible="not show_employee_payee" required="show_employee_payee" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')" options="{'no_create': True}"/>
                            <field name="therapist_name" string="Therapist Name" invisible="not show_therapist_name_input" required="show_therapist_name_input" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>

                            <field name="vendor_name" string="Vendor / Payee Name" invisible="not show_vendor_payee" required="show_vendor_payee" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                            <field name="other_expense_details" invisible="not show_other_expense" required="show_other_expense" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                        </group>
                    </group>

                    <group string="Clinic Transfer Details" invisible="not show_clinic_transfer">
                        <group>
                            <field name="from_clinic_id" required="show_clinic_transfer" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')" options="{'no_create': True}"/>
                            <field name="to_clinic_id" required="show_clinic_transfer" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="therapist_type" invisible="category != 'clinic_to_clinic'" required="category == 'clinic_to_clinic'" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')"/>
                        </group>
                    </group>

                    <group string="Home Visit Patient Details" invisible="not show_home_visit">
                        <group>
                            <field name="home_visit_mrn_search" required="show_home_visit" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')" placeholder="Type MRN and press Tab..."/>
                            <field name="is_cross_cluster_visit" invisible="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="home_visit_patient_name" force_save="1"/>
                            <field name="home_visit_patient_phone" force_save="1"/>
                            <field name="home_visit_patient_clinic" force_save="1"/>
                        </group>
                    </group>

                    <group string="Documents &amp; Compliance Attachments">
                        <group>
                            <field name="is_receipt_mandatory" invisible="1"/>
                            <field name="receipt_file" filename="receipt_filename" string="Vendor Receipt / Bill" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested') or has_pending_allocation"/>
                            <field name="receipt_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="signed_voucher_file" filename="signed_voucher_filename" string="Signed Voucher Asset" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested') or has_pending_allocation"/>
                            <field name="signed_voucher_filename" invisible="1"/>
                        </group>
                    </group>

                    <group string="Payment Proof Breakdown" invisible="state not in ('approved', 'paid', 'refund_requested', 'refunded')">
                        <group>
                            <field name="payment_screenshot" filename="payment_screenshot_filename" string="Transaction Screenshot" readonly="state in ('paid', 'refunded')"/>
                            <field name="payment_screenshot_filename" invisible="1"/>
                            <field name="is_payment_screenshot_image" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Business Purpose"><field name="description" readonly="state in ('approved', 'paid', 'refunded', 'refund_requested')" placeholder="Specify exact context parameters..."/></page>
                        <page string="Current Documents" invisible="not signed_voucher_file and not receipt_file and not payment_screenshot">
                            <div class="row mt-3">
                                <div class="col-4" invisible="not signed_voucher_file">
                                    <h4 style="color: #00a09d; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-bottom: 15px;">Signed Voucher</h4>
                                    <field name="is_signed_voucher_image" invisible="1"/>
                                    <div invisible="not is_signed_voucher_image" style="display: flex; justify-content: center; width: 100%;">
                                        <field name="signed_voucher_preview_image" widget="image" options="{'zoom': true}" readonly="1" nolabel="1"/>
                                    </div>
                                    <div invisible="is_signed_voucher_image" style="width: 100%; height: 600px;">
                                        <field name="signed_voucher_preview_pdf" widget="pdf_viewer" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                                <div class="col-4" invisible="not receipt_file">
                                    <h4 style="color: #00a09d; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-bottom: 15px;">Original Receipt / Vendor Bill</h4>
                                    <field name="is_receipt_image" invisible="1"/>
                                    <div invisible="not is_receipt_image" style="display: flex; justify-content: center; width: 100%;">
                                        <field name="receipt_preview_image" widget="image" options="{'zoom': true}" readonly="1" nolabel="1"/>
                                    </div>
                                    <div invisible="is_receipt_image" style="width: 100%; height: 600px;">
                                        <field name="receipt_preview_pdf" widget="pdf_viewer" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                                <div class="col-4" invisible="not payment_screenshot">
                                    <h4 style="color: #00a09d; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-bottom: 15px;">Transaction Rollout Proof</h4>
                                    <field name="is_payment_screenshot_image" invisible="1"/>
                                    <div invisible="not is_payment_screenshot_image" style="display: flex; justify-content: center; width: 100%;">
                                        <field name="payment_screenshot_preview_image" widget="image" options="{'zoom': true}" readonly="1" nolabel="1"/>
                                    </div>
                                    <div invisible="is_payment_screenshot_image" style="width: 100%; height: 600px;">
                                        <field name="payment_screenshot_preview_pdf" widget="pdf_viewer" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </page>
                        <page string="Archived Original Document" invisible="not old_signed_voucher_file"><field name="old_signed_voucher_file" widget="pdf_viewer" readonly="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div>
            </form>
        </field>
    </record>

    <record id="view_op_fund_disbursement_tree" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.tree</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-warning="state == 'waiting'" decoration-primary="state == 'approved'" decoration-success="state == 'paid'" decoration-muted="state == 'refunded'" delete="0">
                <field name="name"/>
                <field name="date"/>
                <field name="clinic_id"/>
                <field name="payee_display"/>
                <field name="display_category"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'waiting'" decoration-primary="state == 'approved'" decoration-success="state == 'paid'" decoration-danger="state == 'rejected'" decoration-muted="state == 'refunded'"/>

                <field name="s3_receipt_url" optional="hide"/>
                <field name="s3_voucher_url" optional="hide"/>
                <field name="s3_payment_url" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_disbursement" model="ir.actions.act_window">
        <field name="name">Disbursements</field>
        <field name="res_model">operational.fund.disbursement</field>
        <field name="view_mode">kanban,form,tree</field>
    </record>

    <record id="view_op_fund_allocation_form" model="ir.ui.view">
        <field name="name">operational.fund.allocation.form</field>
        <field name="model">operational.fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Wallet Recharge">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="pending,cleared"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="clinic_id" options="{'no_create': True}" readonly="state == 'cleared'"/>
                            <field name="amount" widget="monetary" string="Deposit Amount" readonly="state == 'cleared'"/>
                        </group>
                        <group>
                            <field name="date" readonly="state == 'cleared'"/>
                            <field name="controller_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Recharge notes..." readonly="state == 'cleared'"/>
                    </group>
                    <group string="Acknowledgment Verification File" invisible="state != 'cleared'">
                        <field name="ack_proof_file" filename="ack_proof_filename" widget="pdf_viewer" readonly="1"/>
                        <field name="ack_proof_filename" invisible="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter"><field name="message_follower_ids"/><field name="message_ids"/></div>
            </form>
        </field>
    </record>

    <record id="view_op_fund_allocation_tree" model="ir.ui.view">
        <field name="name">operational.fund.allocation.tree</field>
        <field name="model">operational.fund.allocation</field>
        <field name="arch" type="xml">
            <tree default_order="date desc, id desc">
                <field name="name" string="Receipt No."/>
                <field name="date" string="Date"/>
                <field name="clinic_id" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="notes" string="Purpose"/>
                <field name="amount" sum="Total Lifetime Deposits"/>
                <field name="controller_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-success="state == 'cleared'"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_allocation" model="ir.actions.act_window">
        <field name="name">Wallet Top-ups</field>
        <field name="res_model">operational.fund.allocation</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_op_fund_user_approver_tree" model="ir.ui.view">
        <field name="name">res.users.op.fund.tree</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <tree editable="bottom" create="0" delete="0">
                <field name="name" readonly="1"/>
                <field name="login" readonly="1"/>
                <field name="op_fund_managed_clinic_ids" widget="many2many_tags" options="{'no_create': True}"/>
                <field name="op_fund_ho_managed_clinic_ids" widget="many2many_tags" options="{'no_create': True}"/>
                <field name="op_fund_finance_clinic_ids" widget="many2many_tags" options="{'no_create': True}"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_user_approvers" model="ir.actions.act_window">
        <field name="name">User Approver Setup</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_op_fund_user_approver_tree"/>
        <field name="domain">[('share', '=', False)]</field>
    </record>

    <record id="view_op_fund_clinic_search" model="ir.ui.view">
        <field name="name">op.fund.clinic.search</field>
        <field name="model">clinic.clinic</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="wallet_group_name"/>
                <filter string="Wallet Group" name="group_by_wallet" context="{'group_by': 'wallet_group_name'}"/>
            </search>
        </field>
    </record>

    <record id="view_op_fund_clinic_balance_tree" model="ir.ui.view">
        <field name="name">op.fund.clinic.balance.tree</field>
        <field name="model">clinic.clinic</field>
        <field name="arch" type="xml">
            <tree string="Fund Balances" create="0" delete="0" editable="bottom">
                <field name="name" string="Branch / Clinic" readonly="1"/>
                <field name="master_fund_id" string="Shared Wallet (Master Clinic)" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="wallet_group_name" column_invisible="1"/>
                <field name="op_fund_approval_threshold" widget="monetary" string="Auto-Approval Limit"/>
                <field name="op_fund_alert_threshold" widget="monetary" string="Low Balance Alert At"/>
                <field name="total_allocated" sum="Total Funded" decoration-info="1" readonly="1"/>
                <field name="total_spent" sum="Total Spent" decoration-warning="1" readonly="1"/>
                <field name="op_fund_balance" sum="Total Available Wallet" decoration-success="op_fund_balance &gt; 0" decoration-danger="op_fund_balance == 0" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_clinic_balance" model="ir.actions.act_window">
        <field name="name">Fund Dashboard</field>
        <field name="res_model">clinic.clinic</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_op_fund_audit_tree" model="ir.ui.view">
        <field name="name">operational.fund.audit.tree</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <tree string="Fund Audit Ledger" create="0" edit="0" delete="0" decoration-success="transaction_type == 'credit'" decoration-danger="transaction_type == 'debit'" default_order="date desc, id desc">
                <field name="date"/>
                <field name="clinic_id"/>
                <field name="transaction_type" widget="badge" decoration-success="transaction_type == 'credit'" decoration-danger="transaction_type == 'debit'"/>
                <field name="amount" sum="Total Flow" string="Amount (₹)"/>
                <field name="reference"/>
                <field name="user_id" widget="many2one_avatar_user"/>
            </tree>
        </field>
    </record>

    <record id="view_op_fund_audit_search" model="ir.ui.view">
        <field name="name">operational.fund.audit.search</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <search string="Search Audit Ledger">
                <field name="clinic_id"/>
                <field name="reference"/>
                <field name="user_id"/>
                <filter string="Deposits / Credits" name="filter_credits" domain="[('transaction_type', '=', 'credit')]"/>
                <filter string="Expenses / Debits" name="filter_debits" domain="[('transaction_type', '=', 'debit')]"/>
                <separator/>
                <filter string="This Month" name="this_month" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Clinic" name="group_by_clinic" context="{'group_by': 'clinic_id'}"/>
                    <filter string="Transaction Type" name="group_by_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Date (Month)" name="group_by_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_op_fund_audit_graph" model="ir.ui.view">
        <field name="name">operational.fund.audit.graph</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <graph string="Audit Analysis" type="bar" sample="1">
                <field name="clinic_id"/>
                <field name="transaction_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_op_fund_audit_pivot" model="ir.ui.view">
        <field name="name">operational.fund.audit.pivot</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <pivot string="Audit Pivot Analysis" sample="1">
                <field name="date" type="row" interval="month"/>
                <field name="clinic_id" type="row"/>
                <field name="transaction_type" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_op_fund_audit" model="ir.actions.act_window">
        <field name="name">Audit Ledger</field>
        <field name="res_model">operational.fund.audit</field>
        <field name="view_mode">tree,graph,pivot</field>
    </record>

    <record id="res_config_settings_view_form_op_fund" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.op.fund</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Operational Funds" string="Operational Funds" name="operational_fund" groups="operational_fund.group_op_fund_controller">
                    <block title="AWS S3 Storage Configuration" name="s3_config_block">
                        <setting string="S3 Bucket Name"><field name="op_fund_s3_bucket"/></setting>
                        <setting string="AWS Region"><field name="op_fund_s3_region"/></setting>
                        <setting string="AWS Access Key"><field name="op_fund_s3_access_key"/></setting>
                        <setting string="AWS Secret Key"><field name="op_fund_s3_secret_key" password="True"/></setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_op_fund_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'operational_fund', 'bin_size': False}</field>
    </record>

    <record id="action_bulk_download_disbursement_assets" model="ir.actions.server">
        <field name="name">Bulk Download Assets (Zip)</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="binding_model_id" ref="model_operational_fund_disbursement"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records: action = records.action_bulk_download_assets()
        </field>
    </record>

    <record id="action_migrate_attachments_s3" model="ir.actions.server">
        <field name="name">Migrate Local Files to S3</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="binding_model_id" ref="model_operational_fund_disbursement"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
            action = env['ir.attachment'].action_migrate_local_attachments_to_s3()
        </field>
    </record>
</odoo>