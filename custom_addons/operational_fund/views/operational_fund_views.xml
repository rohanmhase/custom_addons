<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_op_fund_disbursement" model="ir.sequence">
        <field name="name">Operational Fund Disbursement</field>
        <field name="code">operational.fund.disbursement</field>
        <field name="prefix">OFD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="view_op_fund_disbursement_form" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.form</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_print_voucher" string="1. Print Voucher" type="object" class="btn-secondary" icon="fa-print" invisible="state == 'validated'"/>

                    <button name="action_validate" string="2. Validate &amp; Post" type="object" class="oe_highlight" invisible="state == 'validated'"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="alert alert-info text-center" role="alert" invisible="signed_voucher_file != False or state == 'validated'" style="margin-bottom: 20px;">
                        <i class="fa fa-info-circle me-2"></i>
                        <strong>Action Required:</strong> Click <em>Print Voucher</em>, sign the physical document, and upload it below to unlock validation.
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="clinic_id" readonly="state == 'validated'" force_save="1"/>
                            <field name="payee_id" readonly="state == 'validated'"/>
                            <field name="amount" readonly="state == 'validated'"/>
                        </group>
                        <group>
                            <field name="date" readonly="state == 'validated'"/>
                            <field name="category" readonly="state == 'validated'"/>

                            <field name="other_expense_details"
                                   invisible="category != 'other'"
                                   required="category == 'other'"
                                   readonly="state == 'validated'"/>

                            <field name="receipt_file" filename="receipt_filename" readonly="state == 'validated'"/>
                            <field name="receipt_filename" invisible="1"/>
                        </group>
                    </group>

                    <group string="Compliance &amp; Signatures" invisible="state == 'validated' and signed_voucher_file == False">
                        <field name="signed_voucher_file" filename="signed_voucher_filename" readonly="state == 'validated'" widget="Work_Permit_Upload" style="width: 50%;"/>
                        <field name="signed_voucher_filename" invisible="1"/>
                    </group>

                    <notebook>
                        <page string="Business Purpose">
                            <field name="description" readonly="state == 'validated'"
                                   placeholder="Specify the exact purpose of this disbursement..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_op_fund_disbursement_tree" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.tree</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-success="state == 'validated'">
                <field name="name"/>
                <field name="date"/>
                <field name="clinic_id"/>
                <field name="payee_id"/>
                <field name="category"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'"
                       decoration-success="state == 'validated'"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_disbursement" model="ir.actions.act_window">
        <field name="name">Disbursements</field>
        <field name="res_model">operational.fund.disbursement</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_op_fund_allocation_tree" model="ir.ui.view">
        <field name="name">operational.fund.allocation.tree</field>
        <field name="model">operational.fund.allocation</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="date"/>
                <field name="clinic_id"/>
                <field name="reference"/>
                <field name="amount" sum="Total"/>
                <field name="controller_id"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">operational.fund.allocation</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Allocate funds directly to a clinic.
            </p>
            <p>
                You can also import a CSV file from Favorites > Import Records to allocate funds in bulk at the start of
                the month.
            </p>
        </field>
    </record>

    <record id="view_users_form_inherit_clinic" model="ir.ui.view">
        <field name="name">res.users.form.inherit.clinic</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Clinic Assignment">
                    <group>
                        <field name="clinic_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>