<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- SEQUENCES -->
    <record id="seq_op_fund_disbursement" model="ir.sequence">
        <field name="name">Operational Fund Disbursement</field>
        <field name="code">operational.fund.disbursement</field>
        <field name="prefix">OFD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_op_fund_allocation" model="ir.sequence">
        <field name="name">Operational Fund Recharge</field>
        <field name="code">operational.fund.allocation</field>
        <field name="prefix">DEP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- REJECTION WIZARD -->
    <record id="view_op_fund_rejection_wizard_form" model="ir.ui.view">
        <field name="name">operational.fund.rejection.wizard.form</field>
        <field name="model">operational.fund.rejection.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Disbursement">
                <group>
                    <field name="disbursement_id" invisible="1"/>
                    <field name="reason" placeholder="Please provide a detailed reason for rejecting this voucher... (This will be logged in the history)" required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" string="Confirm Reject" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- DISBURSEMENT VIEWS -->
    <record id="view_op_fund_disbursement_kanban" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.kanban</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile" sample="1" records_draggable="0">
                <field name="name"/>
                <field name="clinic_id"/>
                <field name="payee_display"/>
                <field name="amount"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title fs-5"><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_title text-end fw-bold text-success fs-5">₹ <field name="amount"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span class="text-muted"><i class="fa fa-building-o me-1" title="Clinic" aria-label="Clinic"></i> <field name="clinic_id"/></span><br/>
                                    <span class="text-muted"><i class="fa fa-user-o me-1" title="Payee" aria-label="Payee"></i> <field name="payee_display"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_op_fund_disbursement_form" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.form</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <form string="Operational Fund Disbursement" delete="0">
                <header>
                    <button name="action_print_voucher" string="1. Print Voucher" type="object" class="btn-secondary" invisible="state == 'refunded'"/>
                    <button name="action_submit_for_approval" string="Submit for Approval" type="object" class="oe_highlight" invisible="state != 'draft'"/>

                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="state != 'waiting'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state == 'rejected'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>

                    <button name="action_request_refund" string="Request Refund" type="object" class="btn-warning" invisible="state != 'approved'" form_novalidate="1"/>
                    <button name="action_approve_refund" string="Approve Refund" type="object" class="btn-success" invisible="state != 'refund_requested'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>
                    <button name="action_cancel_refund" string="Deny Refund" type="object" class="btn-danger" invisible="state != 'refund_requested'" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>

                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state not in ('rejected', 'approved')" groups="operational_fund.group_op_fund_manager,operational_fund.group_op_fund_controller" form_novalidate="1"/>
                    <button name="action_delete_draft" string="Delete Draft" type="object" class="btn-secondary text-danger" invisible="state != 'draft'" form_novalidate="1"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting,approved,refunded"/>
                </header>
                <sheet>
                    <div class="alert alert-info text-center" role="alert" invisible="signed_voucher_file != False or state in ('waiting', 'approved', 'refund_requested', 'refunded')" style="margin-bottom: 20px;">
                        <i class="fa fa-info-circle me-2" title="Information" aria-label="Information"></i>
                        <strong>Action Required:</strong> Click <em>Print Voucher</em>, sign the physical document, and upload it below to unlock submission.
                    </div>

                    <div class="alert alert-danger text-center" role="alert" invisible="is_cross_cluster_visit == False or state in ('approved', 'refunded')" style="margin-bottom: 20px;">
                        <i class="fa fa-exclamation-triangle me-2" title="Warning" aria-label="Warning"></i>
                        <strong>Cross-Cluster Alert:</strong> This patient is registered outside your clinic cluster. Manager approval is strictly required.
                    </div>

                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="clinic_id" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" force_save="1" options="{'no_create': True, 'no_create_edit': True}"/>

                            <!-- 🚨 DYNAMIC PAYEE FIELDS 🚨 -->
                            <field name="payee_type" widget="radio" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" invisible="category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')"/>
                            <field name="payee_id" invisible="payee_type == 'external' or category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')" required="payee_type == 'internal' and category not in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="vendor_name" invisible="payee_type == 'internal' or category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')" required="payee_type == 'external' and category not in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>
                            <field name="therapist_name" invisible="category not in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')" required="category in ('home_visit_travel', 'fixed_therapist_travel', 'floater_travel', 'clinic_to_clinic')" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>

                            <field name="amount" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>
                        </group>
                        <group>
                            <field name="date" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>
                            <field name="category" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>
                            <field name="other_expense_details" invisible="category != 'other'" required="category == 'other'" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>

                            <field name="is_receipt_mandatory" invisible="1"/>
                            <field name="receipt_file" filename="receipt_filename" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" required="is_receipt_mandatory == True"/>
                            <field name="receipt_filename" invisible="1"/>
                        </group>
                    </group>

                    <!-- 🚨 NEW: CLINIC TO CLINIC DETAILS BLOCK 🚨 -->
                    <group string="Clinic Transfer Details" invisible="category != 'clinic_to_clinic'">
                        <group>
                            <field name="from_clinic_id" required="category == 'clinic_to_clinic'" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" options="{'no_create': True}"/>
                            <field name="to_clinic_id" required="category == 'clinic_to_clinic'" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="therapist_type" required="category == 'clinic_to_clinic'" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')"/>
                        </group>
                    </group>

                    <group string="Home Visit Details" invisible="category != 'home_visit_travel'">
                        <group>
                            <field name="home_visit_mrn_search" required="category == 'home_visit_travel'" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" placeholder="Type MRN and press Tab..."/>
                            <field name="is_cross_cluster_visit" invisible="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="home_visit_patient_name" force_save="1"/>
                            <field name="home_visit_patient_phone" force_save="1"/>
                            <field name="home_visit_patient_clinic" force_save="1"/>
                        </group>
                    </group>

                    <group string="Compliance &amp; Signatures" invisible="state in ('waiting', 'approved', 'refund_requested', 'refunded') and signed_voucher_file == False and old_signed_voucher_file == False">
                        <group>
                            <field name="signed_voucher_file" filename="signed_voucher_filename" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" widget="Work_Permit_Upload" invisible="state == 'refunded'"/>
                            <field name="signed_voucher_filename" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Business Purpose"><field name="description" readonly="state in ('waiting', 'approved', 'refund_requested', 'refunded')" placeholder="Specify the exact purpose of this disbursement..."/></page>

                        <page string="Current Documents" invisible="signed_voucher_file == False and receipt_file == False">
                            <div class="row mt-3">
                                <div class="col-6" invisible="signed_voucher_file == False">
                                    <h4 style="color: #00a09d; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-bottom: 15px;">Signed Voucher</h4>
                                    <field name="signed_voucher_file" widget="pdf_viewer" readonly="1" nolabel="1"/>
                                </div>

                                <div class="col-6" invisible="receipt_file == False">
                                    <h4 style="color: #00a09d; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-bottom: 15px;">Original Receipt / Vendor Bill</h4>
                                    <field name="is_receipt_image" invisible="1"/>
                                    <field name="receipt_file" widget="image" options="{'zoom': true}" invisible="is_receipt_image == False" readonly="1" nolabel="1" style="max-width: 100%; max-height: 600px; display: block; margin: auto;"/>
                                    <field name="receipt_file" widget="pdf_viewer" invisible="is_receipt_image == True" readonly="1" nolabel="1"/>
                                </div>
                            </div>
                        </page>

                        <page string="Archived Original Document" invisible="old_signed_voucher_file == False"><field name="old_signed_voucher_file" widget="pdf_viewer" readonly="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter"><field name="message_follower_ids"/><field name="activity_ids"/><field name="message_ids"/></div>
            </form>
        </field>
    </record>

    <record id="view_op_fund_disbursement_tree" model="ir.ui.view">
        <field name="name">operational.fund.disbursement.tree</field>
        <field name="model">operational.fund.disbursement</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'" decoration-warning="state == 'waiting'" decoration-success="state == 'approved'" decoration-muted="state == 'refunded'" delete="0">
                <field name="name"/>
                <field name="date"/>
                <field name="clinic_id"/>
                <field name="payee_display"/>
                <field name="category"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'waiting'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'" decoration-muted="state == 'refunded'"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_disbursement" model="ir.actions.act_window">
        <field name="name">Disbursements</field>
        <field name="res_model">operational.fund.disbursement</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <!-- WALLET RECHARGE / TOP-UP VIEWS -->
    <record id="view_op_fund_allocation_form" model="ir.ui.view">
        <field name="name">operational.fund.allocation.form</field>
        <field name="model">operational.fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Wallet Recharge">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="clinic_id" options="{'no_create': True}"/>
                            <field name="amount" widget="monetary" string="Deposit Amount"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="controller_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="e.g., Routine monthly top-up, emergency ad-hoc funds, etc."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_op_fund_allocation_tree" model="ir.ui.view">
        <field name="name">operational.fund.allocation.tree</field>
        <field name="model">operational.fund.allocation</field>
        <field name="arch" type="xml">
            <tree default_order="date desc, id desc">
                <field name="name" string="Receipt No."/>
                <field name="date" string="Date"/>
                <field name="clinic_id" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="notes" string="Purpose"/>
                <field name="amount" sum="Total Lifetime Deposits"/>
                <field name="controller_id" widget="many2one_avatar_user"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_allocation" model="ir.actions.act_window">
        <field name="name">Wallet Top-ups</field>
        <field name="res_model">operational.fund.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Log a new fund deposit directly to a clinic wallet.</p>
        </field>
    </record>

    <!-- USER APPROVER SETUP VIEW -->
    <record id="view_op_fund_user_approver_tree" model="ir.ui.view">
        <field name="name">res.users.op.fund.tree</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <tree editable="bottom" create="0" delete="0">
                <field name="name" readonly="1"/>
                <field name="login" readonly="1"/>
                <field name="op_fund_managed_clinic_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="Standard Managed Clinics"/>
                <field name="op_fund_ho_managed_clinic_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="Escalation / HO Clinics"/>
                <field name="op_fund_finance_clinic_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="Finance Managed Clinics"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_user_approvers" model="ir.actions.act_window">
        <field name="name">User Approver Setup</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_op_fund_user_approver_tree"/>
        <field name="domain">[('share', '=', False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Assign internal users to manage specific clinic operational funds.</p>
        </field>
    </record>

    <!-- FUND DASHBOARD -->
    <record id="view_op_fund_clinic_search" model="ir.ui.view">
        <field name="name">op.fund.clinic.search</field>
        <field name="model">clinic.clinic</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="wallet_group_name"/>
                <filter string="Wallet Group" name="group_by_wallet" context="{'group_by': 'wallet_group_name'}"/>
            </search>
        </field>
    </record>

    <record id="view_op_fund_clinic_balance_tree" model="ir.ui.view">
        <field name="name">op.fund.clinic.balance.tree</field>
        <field name="model">clinic.clinic</field>
        <field name="arch" type="xml">
            <tree string="Fund Balances" create="0" delete="0" editable="bottom">
                <field name="name" string="Branch / Clinic" readonly="1"/>
                <field name="master_fund_id" string="Shared Wallet (Master Clinic)" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="wallet_group_name" column_invisible="1"/>
                <field name="op_fund_approval_threshold" widget="monetary" string="Auto-Approval Limit"/>
                <field name="op_fund_alert_threshold" widget="monetary" string="Low Balance Alert At"/>

                <field name="total_allocated" sum="Total Funded" decoration-info="1" readonly="1"/>
                <field name="total_spent" sum="Total Spent" decoration-warning="1" readonly="1"/>
                <field name="op_fund_balance" sum="Total Available Wallet" decoration-success="op_fund_balance &gt; 0" decoration-danger="op_fund_balance == 0" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="action_op_fund_clinic_balance" model="ir.actions.act_window">
        <field name="name">Fund Dashboard</field>
        <field name="res_model">clinic.clinic</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_op_fund_clinic_balance_tree"/>
        <field name="search_view_id" ref="view_op_fund_clinic_search"/>
        <field name="context">{'search_default_group_by_wallet': 1}</field>
    </record>

    <!-- AUDIT LEDGER VIEWS -->
    <record id="view_op_fund_audit_tree" model="ir.ui.view">
        <field name="name">operational.fund.audit.tree</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <tree string="Fund Audit Ledger" create="0" edit="0" delete="0" decoration-success="transaction_type == 'credit'" decoration-danger="transaction_type == 'debit'" default_order="date desc, id desc">
                <field name="date"/>
                <field name="clinic_id"/>
                <field name="transaction_type" widget="badge" decoration-success="transaction_type == 'credit'" decoration-danger="transaction_type == 'debit'"/>
                <field name="amount" sum="Total Flow" string="Amount (₹)"/>
                <field name="reference"/>
                <field name="user_id" widget="many2one_avatar_user"/>
            </tree>
        </field>
    </record>

    <record id="view_op_fund_audit_search" model="ir.ui.view">
        <field name="name">operational.fund.audit.search</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <search string="Search Audit Ledger">
                <field name="clinic_id"/>
                <field name="reference"/>
                <field name="user_id"/>
                <filter string="Deposits / Credits" name="filter_credits" domain="[('transaction_type', '=', 'credit')]"/>
                <filter string="Expenses / Debits" name="filter_debits" domain="[('transaction_type', '=', 'debit')]"/>
                <separator/>
                <filter string="This Month" name="this_month" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Clinic" name="group_by_clinic" context="{'group_by': 'clinic_id'}"/>
                    <filter string="Transaction Type" name="group_by_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Date (Month)" name="group_by_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_op_fund_audit_graph" model="ir.ui.view">
        <field name="name">operational.fund.audit.graph</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <graph string="Audit Analysis" type="bar" sample="1">
                <field name="clinic_id"/>
                <field name="transaction_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_op_fund_audit_pivot" model="ir.ui.view">
        <field name="name">operational.fund.audit.pivot</field>
        <field name="model">operational.fund.audit</field>
        <field name="arch" type="xml">
            <pivot string="Audit Pivot Analysis" sample="1">
                <field name="date" type="row" interval="month"/>
                <field name="clinic_id" type="row"/>
                <field name="transaction_type" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_op_fund_audit" model="ir.actions.act_window">
        <field name="name">Audit Ledger</field>
        <field name="res_model">operational.fund.audit</field>
        <field name="view_mode">tree,graph,pivot</field>
        <field name="search_view_id" ref="view_op_fund_audit_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No transactions yet.</p>
        </field>
    </record>

    <record id="action_sync_pending_alerts" model="ir.actions.server">
        <field name="name">Sync Approval Alerts</field>
        <field name="model_id" ref="model_operational_fund_disbursement"/>
        <field name="binding_model_id" ref="model_operational_fund_disbursement"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_sync_pending_alerts()
        </field>
    </record>
</odoo>