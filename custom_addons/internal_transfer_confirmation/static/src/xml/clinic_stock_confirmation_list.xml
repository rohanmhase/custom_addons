<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="clinic_stock_confirmation.ListView.Buttons"
       t-inherit="web.ListView.Buttons"
       t-inherit-mode="primary">

        <xpath expr="//div[hasclass('o_list_buttons')]" position="inside">
            <button type="button"
                    class="btn btn-success o_clinic_confirm_all_btn"
                    t-on-click="onClickConfirmAll">
                Confirm All
            </button>
        </xpath>
    </t>
</templates>