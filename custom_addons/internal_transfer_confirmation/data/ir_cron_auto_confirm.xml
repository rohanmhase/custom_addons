<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_auto_confirm_pending" model="ir.cron">
            <field name="name">Clinic Stock: Auto-Confirm Pending</field>
            <field name="model_id" ref="model_clinic_stock_confirmation_autoconfirm"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_confirm_pending()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <record id="param_auto_confirm_hour_ist" model="ir.config_parameter">
            <field name="key">internal_transfer_confirmation.auto_confirm_hour_ist</field>
            <field name="value">17</field>
        </record>

        <record id="param_auto_confirm_minute_ist" model="ir.config_parameter">
            <field name="key">internal_transfer_confirmation.auto_confirm_minute_ist</field>
            <field name="value">0</field>
        </record>

    </data>
</odoo>