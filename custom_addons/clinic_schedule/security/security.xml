<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_clinic_schedule">
        <field name="name">Clinic Scheduling</field>
        <field name="description">Access rights for the Clinical Matrix Dashboard</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_clinic_schedule_viewer" model="res.groups">
        <field name="name">Viewer (Read-Only)</field>
        <field name="category_id" ref="module_category_clinic_schedule"/>
    </record>

    <record id="group_clinic_schedule_clinic_admin" model="res.groups">
        <field name="name">Clinic Admin (Manage Appointments &amp; Leaves)</field>
        <field name="category_id" ref="module_category_clinic_schedule"/>
        <field name="implied_ids" eval="[(4, ref('group_clinic_schedule_viewer'))]"/>
    </record>

    <record id="group_clinic_schedule_manager" model="res.groups">
        <field name="name">Back Office Manager (Full Access)</field>
        <field name="category_id" ref="module_category_clinic_schedule"/>
        <field name="implied_ids" eval="[(4, ref('group_clinic_schedule_clinic_admin'))]"/>
    </record>
</odoo>