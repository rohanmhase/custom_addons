<odoo>

    <record id="view_clinic_stock_replenishment_form" model="ir.ui.view">
        <field name="name">clinic.stock.replenishment.form</field>
        <field name="model">clinic.stock.replenishment</field>
        <field name="arch" type="xml">
            <form string="Clinic Stock Replenishment">

                <header>
                    <field name="state" widget="statusbar"/>

                    <button name="action_generate_transfers"
                            type="object"
                            string="Generate Transfers"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="clinic_stock_replenishment.group_clinic_stock_user"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive"
                                string="Archive"
                                invisible="active == False"/>
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive"
                                string="Unarchive"
                                invisible="active == True"/>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active == True"/>
                    <field name="active" invisible="1"/>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                        </group>

                        <group>
                            <field name="source_warehouse_id"
                                   domain="[('id', 'not in', destination_warehouse_ids)]"/>

                            <field name="region_id"/>

                            <field name="destination_warehouse_ids"
                                   widget="many2many_tags"
                                   domain="[('id', '!=', source_warehouse_id)]"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Snapshot Log" name="snapshot_log">
                            <button name="action_open_log"
                                    type="object"
                                    string="Open Full Log"
                                    class="btn-secondary mb-2"/>
                            <field name="log_ids" readonly="1"
                                   context="{'search_view_ref': 'clinic_stock_replenishment.view_clinic_stock_replenishment_log_search'}">
                                <tree>
                                    <field name="snapshot_datetime" string="Date &amp; Time"/>
                                    <field name="destination_warehouse_id" string="Destination Clinic"/>
                                    <field name="product_id" string="Medicine"/>
                                    <field name="day_1_count" string="Day -1"/>
                                    <field name="day_2_count" string="Day -2"/>
                                    <field name="day_3_count" string="Day -3"/>
                                    <field name="max_therapy_count" string="Max Count"/>
                                    <field name="gender_session_count" string="M / F Sessions"/>
                                    <field name="target_qty" string="Target"/>
                                    <field name="current_stock" string="Stock"/>
                                    <field name="shortage_qty" string="Shortage"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <record id="view_clinic_stock_replenishment_tree" model="ir.ui.view">
        <field name="name">clinic.stock.replenishment.tree</field>
        <field name="model">clinic.stock.replenishment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>


    <record id="action_clinic_stock_replenishment"
            model="ir.actions.act_window">
        <field name="name">Clinic Stock Replenishments</field>
        <field name="res_model">clinic.stock.replenishment</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="view_clinic_stock_replenishment_log_search" model="ir.ui.view">
        <field name="name">clinic.stock.replenishment.log.search</field>
        <field name="model">clinic.stock.replenishment.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="destination_warehouse_id" string="Destination Clinic"
                       filter_domain="[('destination_warehouse_id', 'ilike', self)]"/>
                <field name="product_id" string="Medicine"
                       filter_domain="[('product_id', 'ilike', self)]"/>
                <field name="source_warehouse_id" string="Source Warehouse"
                       filter_domain="[('source_warehouse_id', 'ilike', self)]"/>
                <filter string="Has Shortage" name="has_shortage" domain="[('shortage_qty', '>', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Destination Clinic" name="group_destination"
                            context="{'group_by': 'destination_warehouse_id'}"/>
                    <filter string="Medicine" name="group_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_clinic_stock_replenishment_log_tree" model="ir.ui.view">
        <field name="name">clinic.stock.replenishment.log.tree</field>
        <field name="model">clinic.stock.replenishment.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="snapshot_datetime" string="Date &amp; Time"/>
                <field name="destination_warehouse_id" string="Destination Clinic"/>
                <field name="product_id" string="Medicine"/>
                <field name="day_1_count" string="Day -1"/>
                <field name="day_2_count" string="Day -2"/>
                <field name="day_3_count" string="Day -3"/>
                <field name="max_therapy_count" string="Max Count"/>
                <field name="gender_session_count" string="M / F Sessions"/>
                <field name="target_qty" string="Target"/>
                <field name="current_stock" string="Stock"/>
                <field name="shortage_qty" string="Shortage"/>
            </tree>
        </field>
    </record>

    <menuitem id="menu_clinic_stock_root"
              name="Clinic Stock Replenishment"
              parent="stock.menu_stock_root"
              groups="clinic_stock_replenishment.group_clinic_stock_viewer"/>

    <menuitem id="menu_clinic_stock_replenishment"
              name="Stock Replenishment"
              parent="menu_clinic_stock_root"
              action="action_clinic_stock_replenishment"
              groups="clinic_stock_replenishment.group_clinic_stock_viewer"/>

</odoo>