<odoo>
    <record id="view_clinic_dashboard_form" model="ir.ui.view">
        <field name="name">clinic.dashboard.form</field>
        <field name="model">clinic.dashboard</field>
        <field name="arch" type="xml">
            <form string="Clinic Dashboard">
                <sheet>
                    <group>
                        <group>
                            <field name="clinic_id" readonly="1" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="from_date"/>
                        </group>
                        <group>
                            <field name="to_date"/>
                        </group>
                    </group>


                    <div class="row mt-4">

                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card shadow-sm border-0 h-100"
                                 style="background-color: #f8f9fa; border-radius: 8px;">
                                <div class="card-body text-center p-4">
                                    <h6 class="text-muted mb-2" style="text-transform: uppercase; font-weight: bold;">
                                        Total Patients
                                    </h6>
                                    <h2 class="mb-0 text-primary" style="font-size: 36px; font-weight: bold;">
                                        <field name="total_patients" readonly="1" nolabel="1"/>
                                    </h2>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card shadow-sm border-0 h-100"
                                 style="background-color: #f8f9fa; border-radius: 8px;">
                                <div class="card-body text-center p-4">
                                    <h6 class="text-muted mb-2" style="text-transform: uppercase; font-weight: bold;">
                                        New Patients
                                    </h6>
                                    <h2 class="mb-3 text-info" style="font-size: 36px; font-weight: bold;">
                                        <field name="today_registered_patients" readonly="1" nolabel="1"/>
                                    </h2>
                                    <button name="action_view_new_patients" type="object" string="View List"
                                            class="btn btn-outline-info btn-sm"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card shadow-sm border-0 h-100"
                                 style="background-color: #f8f9fa; border-radius: 8px;">
                                <div class="card-body text-center p-4">
                                    <h6 class="text-muted mb-2" style="text-transform: uppercase; font-weight: bold;">
                                        Enrollments
                                    </h6>
                                    <h2 class="mb-3 text-success" style="font-size: 36px; font-weight: bold;">
                                        <field name="total_enrollment" readonly="1" nolabel="1"/>
                                    </h2>
                                    <button name="action_view_enrollments" type="object" string="View List"
                                            class="btn btn-outline-success btn-sm"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card shadow-sm border-0 h-100"
                                 style="background-color: #f8f9fa; border-radius: 8px;">
                                <div class="card-body text-center p-4">
                                    <h6 class="text-muted mb-2" style="text-transform: uppercase; font-weight: bold;">
                                        Therapies
                                    </h6>
                                    <h2 class="mb-3 text-warning" style="font-size: 36px; font-weight: bold;">
                                        <field name="total_therapies" readonly="1" nolabel="1"/>
                                    </h2>
                                    <button name="action_view_therapies" type="object" string="View List"
                                            class="btn btn-outline-warning btn-sm"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card shadow-sm border-0 h-100"
                                 style="background-color: #f8f9fa; border-radius: 8px;">
                                <div class="card-body text-center p-4">
                                    <h6 class="text-muted mb-2" style="text-transform: uppercase; font-weight: bold;">CS
                                        Followups
                                    </h6>
                                    <h2 class="mb-3 text-danger" style="font-size: 36px; font-weight: bold;">
                                        <field name="total_daily_followups" readonly="1" nolabel="1"/>
                                    </h2>
                                    <button name="action_view_cs_followups" type="object" string="View List"
                                            class="btn btn-outline-danger btn-sm"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="card shadow-sm border-0 h-100"
                                 style="background-color: #f8f9fa; border-radius: 8px;">
                                <div class="card-body text-center p-4">
                                    <h6 class="text-muted mb-2" style="text-transform: uppercase; font-weight: bold;">RS
                                        Followups
                                    </h6>
                                    <h2 class="mb-3 text-dark" style="font-size: 36px; font-weight: bold;">
                                        <field name="total_followups" readonly="1" nolabel="1"/>
                                    </h2>
                                    <button name="action_view_rs_followups" type="object" string="View List"
                                            class="btn btn-outline-dark btn-sm"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>