<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_open_pos_cash_wizard" model="ir.actions.act_window">
            <field name="name">Force Session Cash Adjustment</field>
            <field name="res_model">pos.session.cash.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_pos_session_id': active_id}</field>
        </record>

        <record id="view_pos_session_form_inherit_cash_adj" model="ir.ui.view">
            <field name="name">pos.session.form.inherit.cash.adj</field>
            <field name="model">pos.session</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="%(clinic_management.action_open_pos_cash_wizard)d"
                            string="Adjust Cash Entry"
                            type="action"
                            class="btn-danger"
                            groups="base.group_system"
                            invisible="state != 'closed'"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>