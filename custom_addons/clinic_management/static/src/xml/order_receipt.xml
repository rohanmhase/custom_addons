<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt')]//ReceiptHeader" position="after">
            <div style="text-align: center; font-weight: bold; font-size: 14px; margin-top: -40px;">
                MEDICINE DISPATCHED
            </div>
            <div t-if="props.data.partner_name_only" style="text-align: center; margin-bottom: 10px; margin-top: 20px; font-size:18px">
                <b>Patient:</b>  <t t-esc="props.data.partner_name_only"/>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('pos-receipt')]//OrderWidget" position="before">
            <div style="display: flex; justify-content: space-between;  padding-bottom: 3px; font-weight: bold; margin-bottom: 10px;">
                <span>Medicine</span>
                <span>Qty</span>
            </div>
        </xpath>
<!--        <xpath expr="//div[hasclass('pos-receipt')]//OrderWidget" position="before">-->
<!--            <div style="display: flex; justify-content: space-between; border-bottom: 1px  padding-bottom: 3px; font-weight: bold; margin-bottom: 5px;">-->
<!--                <span>Medicine</span>-->
<!--                <span>Qty</span>-->
<!--            </div>-->
<!--        </xpath>-->


        <xpath expr="//div[hasclass('pos-receipt')]//Orderline" position="inside">
            <span class="custom-qty-display" style="float: right;">
                <t t-esc="line.qty"/>
            </span>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt')]//OrderWidget" position="after">
            <div style="border-top: 1px dashed black; width: 100%; margin-top: 5px;"/>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt')]//div[hasclass('pos-receipt-taxes')]" position="attributes">
            <attribute name="style">display: none !important;</attribute>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt')]//div[hasclass('before-footer')]" position="attributes">
            <attribute name="style">display: none !important;</attribute>
        </xpath>

        <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
            <div style="display: flex; justify-content: space-between; margin-top: 30px; padding: 0 10px; clear: both; width: 100%;">
                <div style="border-top: 1px solid black; width: 40%; text-align: center; font-size: 0.8em;">
                    Patient Signature
                </div>
                <div style="border-top: 1px solid black; width: 40%; text-align: center; font-size: 0.8em;">
                    Admin Signature
                </div>
            </div>
        </xpath>
        <xpath expr="//div[contains(@style, 'border-top')]" position="replace">
            <!-- empty = removed -->
        </xpath>
        <xpath expr="//div[@class='pos-receipt-right-align' and contains(text(), '----')]" position="replace">
            <!-- removed -->
        </xpath>
    </t>
</templates>